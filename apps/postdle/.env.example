# ===== 포스트들(Postdle) 환경변수 =====
# 로컬 개발 시 .env 로 복사해서 채우세요.

# --- pagedle 백엔드 (회원·DB 공유) ---
# 운영: https://api.pagedle.com/api/v1
PAGEDLE_API="https://api.pagedle.com/api/v1"

# --- 도메인 ---
NEXT_PUBLIC_ROOT_DOMAIN="postdle.com"
# 로컬은 lvh.me 권장 (서브도메인 테스트: user.lvh.me:3000 → 127.0.0.1)
# NEXT_PUBLIC_ROOT_DOMAIN="lvh.me:3000"
